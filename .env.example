# Groq API Keys (up to 10 for automatic rotation)
GROQ_KEY_1=gsk_your_key_1_here
GROQ_KEY_2=gsk_your_key_2_here
GROQ_KEY_3=gsk_your_key_3_here
GROQ_KEY_4=
GROQ_KEY_5=
GROQ_KEY_6=
GROQ_KEY_7=
GROQ_KEY_8=
GROQ_KEY_9=
GROQ_KEY_10=

# Video Source Settings
SOURCE_FEED_URL=https://www.youtube.com/@HubermanLab/videos
MAX_FEED_ITEMS=5

# Ramp-Up Schedule Settings
# RAMPUP_MODE=true: 3 uploads/day (8 hours interval) for new accounts
# RAMPUP_MODE=false: 10 uploads/day (2.4 hours interval) for established accounts
RAMPUP_MODE=true
RAMPUP_INTERVAL_SEC=28800
STANDARD_INTERVAL_SEC=8640
RETRY_DELAY_SEC=60
